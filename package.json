{
  "name": "murmur",
  "version": "0.1.1",
  "description": "Privacy-focused meeting capture & transcription for Windows — local Whisper, Obsidian output",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:python": "cd python && python build.py",
    "build": "electron-builder --win",
    "split-backend": "node scripts/split-backend.js",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "io.gremble.murmur",
    "productName": "Murmur",
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "publish": {
      "provider": "github",
      "owner": "jlevy-dev",
      "repo": "Murmur"
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "deleteAppDataOnUninstall": false
    },
    "files": [
      "main.js",
      "preload.js",
      "backend-downloader.js",
      "renderer/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ]
  },
  "dependencies": {
    "electron-store": "^10.0.0",
    "electron-updater": "^6.3.9",
    "ws": "^8.20.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^26.0.0"
  }
}
